pipeline {
    agent any

    environment {
        APPLICATION = 'orders'
        VERSION = '1.0.0'
    }

    stages {
        stage('Resolve Target') {
            steps {
                script {
                    if (env.BRANCH_NAME == 'develop') {
                        env.TARGET_ENV = 'dev'
                    } else if (env.BRANCH_NAME == 'qa') {
                        env.TARGET_ENV = 'qa'
                    } else if (env.BRANCH_NAME == 'main') {
                        env.TARGET_ENV = 'prd'
                    } else {
                        env.TARGET_ENV = 'none'
                    }

                    echo "Branch: ${env.BRANCH_NAME}"
                    echo "Target environment: ${env.TARGET_ENV}"
                }
            }
        }

        stage('Validate') {
            steps {
                echo "Validating repository structure..."
                powershell """
                    if (!(Test-Path ".\\applications\\${env.APPLICATION}\\${env.VERSION}\\mqsc")) {
                        throw "MQSC folder not found"
                    }

                    Get-ChildItem ".\\applications\\${env.APPLICATION}\\${env.VERSION}\\mqsc" -Filter "*.mqsc"
                """
            }
        }

        stage('Deploy MQ Objects') {
            when {
                expression {
                    return env.TARGET_ENV != 'none'
                }
            }
            steps {
                powershell """
                    .\\scripts\\deploy.ps1 `
                        -Environment ${env.TARGET_ENV} `
                        -Application ${env.APPLICATION} `
                        -Version ${env.VERSION}
                """
            }
        }

        stage('Skip Deployment') {
            when {
                expression {
                    return env.TARGET_ENV == 'none'
                }
            }
            steps {
                echo "Feature branch detected. Validation only. No deployment executed."
            }
        }
    }
}